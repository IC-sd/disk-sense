{
  "name": "disk-sense-rewrite",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron desktop/main.cjs --dev\"",
    "build": "vite build",
    "start:desktop": "electron desktop/main.cjs",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "vue-tsc": "^2.1.0",
    "concurrently": "^9.0.0",
    "wait-on": "^8.0.0",
    "electron": "^30.0.0"
  }
}
